{
  "version": 2,
  "headers": [
    {
      "source": "/stellarium/(.*)\\.wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/imaging/cleanup-sessions",
      "schedule": "0 5 * * *"
    }
  ]
}

